# ============================================================
# LeadwayHMO RxHub — Environment Variables
# ============================================================

# App
APP_NAME=LeadwayHMO RxHub
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rxhub

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ADMIN_TOKEN_EXPIRE_MINUTES=480

# PBM External API
PBM_API_BASE_URL=https://pbm-api.leadwayhmo.com
PBM_API_KEY=your-pbm-api-key
PBM_API_TIMEOUT=30

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3

# SMS (Termii)
SMS_PROVIDER=TERMII
SMS_API_KEY=your-termii-api-key
SMS_SENDER_ID=LeadwayHMO

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=rxhub-uploads
AWS_S3_REGION=eu-west-1

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
