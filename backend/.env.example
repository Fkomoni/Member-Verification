# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/member_verification

# JWT Secret - generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME

# Biometric encryption key - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIC_ENCRYPTION_KEY=CHANGE-ME

# Futronic FS80H
FUTRONIC_SDK_AVAILABLE=true    # set "false" for dev/CI without scanner hardware
FUTRONIC_MATCH_THRESHOLD=800   # 0-10000 — higher = stricter matching
REQUIRE_LFD=true               # enforce Live Finger Detection on all scans

# Prognosis core system integration
PROGNOSIS_BASE_URL=https://prognosis.example.com/api/v1
PROGNOSIS_API_KEY=
