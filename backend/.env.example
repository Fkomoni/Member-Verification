# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/member_verification

# JWT Secret - generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME

# Biometric encryption key - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIC_ENCRYPTION_KEY=CHANGE-ME

# Futronic FS80H
FUTRONIC_SDK_AVAILABLE=true
FUTRONIC_MATCH_THRESHOLD=800
REQUIRE_LFD=true

# Prognosis (Leadway Health) API
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com
PROGNOSIS_USERNAME=
PROGNOSIS_PASSWORD=

# WellaHealth API (acute medication fulfilment)
WELLAHEALTH_BASE_URL=https://staging.wellahealth.com/public/v1
WELLAHEALTH_PARTNER_CODE=
WELLAHEALTH_CLIENT_ID=
WELLAHEALTH_CLIENT_SECRET=

# Google Maps Geolocation API
GOOGLE_MAPS_API_KEY=

# Leadway WhatsApp routing numbers
WHATSAPP_LAGOS_NUMBER=
WHATSAPP_OUTSIDE_LAGOS_NUMBER=
